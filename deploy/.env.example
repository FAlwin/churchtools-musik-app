# Diese Datei nach ".env" kopieren und ausfüllen. Sie gehört NICHT ins Git.

# Pflicht: Basis-URL EURER ChurchTools-Instanz (ohne abschließenden Slash).
CHURCHTOOLS_BASE_URL=https://eure-gemeinde.church.tools

# Pflicht: langer Zufallsstring zum Signieren des Login-Cookies.
# Einmalig erzeugen mit:  openssl rand -hex 32
SESSION_SECRET=

# Optional: ChurchTools-Recht (Form `modul:recht`), das als "Administrator" gilt
# und das Setzen des Gemeindenamens in der App freischaltet.
# Default deckt Voll-Admins ab – nur ändern, wenn nötig.
#ADMIN_PERMISSION=churchcore:administer persons

# Optional: Auf "true" setzen, wenn die App AUSSCHLIESSLICH über HTTPS erreichbar ist
# (z. B. hinter einem Reverse Proxy / Cloudflare). Dann wird das Login-Cookie nur über
# HTTPS gesendet (sicherer). NICHT setzen, wenn ihr die App im lokalen Netz über
# http://… nutzt – sonst klappt das Anmelden nicht. Standard: false.
#COOKIE_SECURE=false
