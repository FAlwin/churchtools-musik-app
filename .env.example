# ── ChurchTools ──────────────────────────────────────────────
# Basis-URL der ChurchTools-Instanz (ohne abschließenden Slash)
CHURCHTOOLS_BASE_URL=https://ecg-donrath.church.tools

# Persönlicher Login-Token NUR für die API-Erkundung (Probe-Skript).
# In ChurchTools: eigenes Profil → Einstellungen → "Berechtigungen"/Sicherheit
# → Login-Token erzeugen. Jederzeit widerrufbar. Wird NICHT committet.
CHURCHTOOLS_LOGIN_TOKEN=

# ── Server ───────────────────────────────────────────────────
# Port des Express-Backends
PORT=3001
# Umgebung: development | production
NODE_ENV=development
# Geheimnis zum Signieren des Session-Cookies (langer Zufallsstring!)
SESSION_SECRET=bitte-langen-zufallsstring-eintragen

# ── White-Label / Laufzeit-Branding (optional) ───────────────
# Ablageort der Branding-Datei (Name/Logo/Farben/CCLI). Auf einem persistenten
# Docker-Volume ablegen, damit Updates die Einstellungen nicht löschen.
SITE_CONFIG_PATH=./data/site.json
# ChurchTools-Recht (Form `modul:recht`), das als „Administrator" gilt und die
# Branding-Einstellungen freischaltet. Default deckt Voll-Admins ab; je nach
# Instanz ggf. anpassen.
ADMIN_PERMISSION=churchcore:administer persons

# ── Client (nur Dev) ─────────────────────────────────────────
# Im Dev leitet der Vite-Proxy /api an den Server; in Produktion liefert
# der Server die App selbst aus (gleiche Adresse) – dann nicht nötig.
VITE_API_BASE_URL=http://localhost:3001

# Hinweis: Der externe Zugang (https://musik.ecg-donrath.de) läuft über den
# Synology Reverse Proxy – dafür sind KEINE zusätzlichen .env-Werte nötig.
