# Diese Datei nach „.env" kopieren und ausfüllen. NICHT weitergeben.

# Adresse eurer ChurchTools-Instanz (ohne Schrägstrich am Ende)
CHURCHTOOLS_BASE_URL=https://eure-gemeinde.church.tools

# Langer, zufälliger Geheimtext zum Signieren der Anmelde-Cookies.
# Erzeugen z. B. mit:  openssl rand -hex 32
SESSION_SECRET=hier-langen-zufallsstring-eintragen

# Optional: Welches ChurchTools-Recht als „Administrator" gilt (darf das
# Erscheinungsbild ändern). Standard passt für Voll-Admins; nur ändern, wenn nötig.
# ADMIN_PERMISSION=churchcore:administer persons
