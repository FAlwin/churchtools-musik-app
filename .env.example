# ── ChurchTools ──────────────────────────────────────────────
# Basis-URL der ChurchTools-Instanz (ohne abschließenden Slash)
CHURCHTOOLS_BASE_URL=https://ecg-donrath.church.tools

# Persönlicher Login-Token NUR für die API-Erkundung (Probe-Skript).
# In ChurchTools: eigenes Profil → Einstellungen → "Berechtigungen"/Sicherheit
# → Login-Token erzeugen. Jederzeit widerrufbar. Wird NICHT committet.
CHURCHTOOLS_LOGIN_TOKEN=

# ── Server ───────────────────────────────────────────────────
# Port des Express-Backends
PORT=3001
# Umgebung: development | production
NODE_ENV=development
# Geheimnis zum Signieren des Session-Cookies (langer Zufallsstring!)
SESSION_SECRET=bitte-langen-zufallsstring-eintragen

# ── Client ───────────────────────────────────────────────────
# Basis-URL, unter der der Client das Backend erreicht
VITE_API_BASE_URL=http://localhost:3001
