# ── ChurchTools ──────────────────────────────────────────────
# PFLICHT: Basis-URL DEINER ChurchTools-Instanz (ohne abschließenden Slash).
# Ohne diesen Wert startet die App bewusst nicht – so redet keine
# fehlkonfigurierte Instanz versehentlich mit einem fremden ChurchTools.
CHURCHTOOLS_BASE_URL=https://deine-gemeinde.church.tools

# Persönlicher Login-Token NUR für die API-Erkundung (Probe-Skript).
# In ChurchTools: eigenes Profil → Einstellungen → "Berechtigungen"/Sicherheit
# → Login-Token erzeugen. Jederzeit widerrufbar. Wird NICHT committet.
CHURCHTOOLS_LOGIN_TOKEN=

# ── Server ───────────────────────────────────────────────────
# Port des Express-Backends
PORT=3001
# Umgebung: development | production
NODE_ENV=development
# PFLICHT in Produktion: Geheimnis zum Signieren des Session-Cookies.
# In Produktion (NODE_ENV=production) startet die App OHNE diesen Wert bewusst nicht.
# Langen Zufallsstring erzeugen, z. B.:  openssl rand -hex 32
SESSION_SECRET=bitte-langen-zufallsstring-eintragen
# Auf "true" setzen, wenn die App nur über HTTPS läuft (Reverse Proxy/Cloudflare) –
# dann wird das Login-Cookie nur über HTTPS gesendet. Im LAN-HTTP-Betrieb aus lassen.
COOKIE_SECURE=false

# ── Laufzeit-Einstellungen ───────────────────────────────────
# Ablageort der Einstellungs-Datei (Gemeindename). Auf einem persistenten
# Docker-Volume ablegen, damit Updates die Einstellungen nicht löschen.
# Der Gemeindename selbst wird IN der App gesetzt (Admin → „Mehr"-Tab),
# nicht hier in der .env.
SITE_CONFIG_PATH=./data/site.json
# Ablageordner der kontobezogenen Anmerkungen (eine JSON-Datei je ChurchTools-Konto).
ANNOTATIONS_PATH=./data/annotations
# Rechte-Cache: merkt sich pro Konto die zuletzt gültigen ChurchTools-Rechte und überbrückt
# damit sporadische CT-Aussetzer (leere Rechte-Antwort). Ebenfalls aufs Volume legen.
CAPABILITIES_CACHE_PATH=./data/capabilities-cache.json
# ChurchTools-Recht (Form `modul:recht`), das als „Administrator" gilt und die
# Einstellungen freischaltet. Default deckt Voll-Admins ab; je nach Instanz
# ggf. anpassen.
ADMIN_PERMISSION=churchcore:administer persons

# ── Client (nur Dev) ─────────────────────────────────────────
# Im Dev leitet der Vite-Proxy /api an den Server; in Produktion liefert
# der Server die App selbst aus (gleiche Adresse) – dann nicht nötig.
VITE_API_BASE_URL=http://localhost:3001

# Hinweis: Externer Zugang läuft typischerweise über einen Reverse Proxy
# (z. B. Synology) mit HTTPS – dafür sind KEINE zusätzlichen .env-Werte nötig.
